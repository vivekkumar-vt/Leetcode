class Solution {
    public String mapWordWeights(String[] words, int[] weights) {
        StringBuilder ans = new StringBuilder();
        for(String w:words){
            int sum=0;
            for(char ch :w.toCharArray()){
                sum=sum+weights[ch-'a'];
            }
            int mod=sum % 26;
            ans.append((char)('z'-mod));
        }
        return ans.toString();
    }
}