class Solution {
    public int calculate(String s) {
        Stack<Integer> st = new Stack<>();
        int n= s.length();
        int ans = 0;
        int num = 0;
        int sign = 1;

        for(int i=0;i<n;i++){
            char ch=s.charAt(i);
            if (Character.isDigit(ch)) {
                num=num*10+(ch-'0');
            }
            else if(ch=='+'){
                ans= ans+sign*num;
                num= 0;
                sign=1;
            }
            else if(ch=='-'){
                ans= ans+sign*num;
                num= 0;
                sign=-1;
            }
            else if(ch=='('){
                st.push(ans);
                st.push(sign);
                ans = 0;
                sign = 1;
            }
            else if(ch==')'){
                ans= ans+sign*num;
                num= 0;
                ans= ans*st.pop();
                ans = ans+st.pop(); 
            }
        }
        ans= ans+sign*num;
        return ans;
    }
}