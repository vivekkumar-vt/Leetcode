class Solution {
    public char processStr(String s, long k){
        int n = s.length();
        long[] len = new long[n];
        long cur = 0;
        for(int i = 0; i < n; i++){
            char ch = s.charAt(i);
            if(ch == '*'){
                if(cur > 0){
                    cur--;
                }
            }
            else if(ch == '#'){
                cur *= 2;
            } 
            else if(ch == '%'){
                
            } 
            else{
                cur++;
            }
            len[i] = cur;
        }

        if(k >= cur){
            return '.';
        }

        for(int i = n - 1; i >= 0; i--){
            char ch = s.charAt(i);
            long cLen = len[i];

            if(ch == '*'){
                //k = cLen;
            }
            else if(ch == '#'){
                long half = cLen / 2;
                if (k>= half) k-= half;
            }
            else if(ch == '%'){
                k= cLen-1-k;
            }
            else{
                if(k== cLen -1) {
                    return ch;
                }
            }
        }
        return '.';
        
