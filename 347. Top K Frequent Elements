class Solution {
    public int[] topKFrequent(int[] nums, int k) {
        int n = nums.length;
        class Pairs{
            int first; int second;
            Pairs(int f , int s){
                first =f; second = s;
            }
        }
        PriorityQueue<Pairs> pq = new PriorityQueue<>((a,b)->{
            if(a.first!=b.first){
                return a.first-b.first;
            }
             return a.second - b.second;
        });
        HashMap<Integer,Integer> h = new HashMap<>();
        for(int i=0;i<n;i++){
            h.put(nums[i], h.getOrDefault(nums[i],0)+1);
        }
        for(Map.Entry<Integer,Integer> en : h.entrySet()){
            int ele = en.getKey();
            int fre = en.getValue();
            Pairs curr = new Pairs(fre,ele);
            if(pq.size()<k){
                pq.offer(curr);
                continue;
            }
            if(curr.first > pq.peek().first){
                pq.poll();
                pq.offer(curr);
            }
        }

        ArrayList<Integer> res = new ArrayList<>();
        while(!pq.isEmpty()){
            res.add(pq.peek().second);
            pq.poll();
        }
        int[] ans = new int[k];

        for (int i = 0; i < k; i++) {
            ans[i] = res.get(i);
        }

        return ans;
    }
}