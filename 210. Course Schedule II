class Solution {
    public int[] findOrder(int numCourses, int[][] prerequisites) {
        int n= numCourses;
        ArrayList<ArrayList<Integer>> graph = new ArrayList<>();
        for(int i = 0; i < n; i++){
            graph.add(new ArrayList<>());
        }
        for (int[] p : prerequisites) {
            graph.get(p[1]).add(p[0]);
        }

        int indeg[]= new int[n];
        for(int i=0;i<n;i++){
            for(int neigh : graph.get(i)){
                indeg[neigh]++;
            }
        }
       Queue<Integer> q = new LinkedList<>();
        for(int i=0; i<n;i++){
            if(indeg[i]==0){
               q.offer(i);
            }
        }
        int res[] = new int[n]; int idx=0;
        while(!q.isEmpty()){
            int node = q.poll();
            res[idx++]=node;
            for(int neigh : graph.get(node)){
                indeg[neigh]--;
                if(indeg[neigh]==0){
                    q.offer(neigh);
                }
            }
        }
        if(idx!=n){
            return new int[0];
        }
        return res;
    }

}