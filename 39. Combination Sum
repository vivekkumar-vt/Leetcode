class Solution {
    public List<List<Integer>> combinationSum(int[] candidates, int target) {
        int n=candidates.length;
        int sum=0; int idx=0;
        ArrayList<Integer> diary = new ArrayList<>();
        List<List<Integer>> res = new ArrayList<>();

        fun(candidates, n,idx,diary,target,sum,res);
        return res;
    }
    private void fun(int [] candidates, int n, int idx,ArrayList<Integer> diary,int target, int sum, List<List<Integer>> res ){
        if(idx==n){
            if(sum==target){
                res.add(new ArrayList<>(diary));
            }
                return;
        }
        fun(candidates,n,idx+1,diary,target,sum,res);
        if(candidates[idx]+sum <= target){
            diary.add(candidates[idx]);
            sum=sum+candidates[idx];
            fun(candidates,n,idx,diary,target,sum,res);
            diary.remove(diary.size()-1);
            sum = sum-candidates[idx];
        }
        return;
    }
}