class Solution {
    public long sumAndMultiply(int n) {
        int x=0; int p=1; int sum=0;
        while(n>0){
            int d=n%10;
            if(d!=0){
                x=x+d*p;
                sum=sum+d;
                p=p*10;
            }
            n=n/10;
        }
        return 1L*x*sum;
    }
}