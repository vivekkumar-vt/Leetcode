class Solution {
    public int kthSmallest(int[][] matrix, int k) {
        int n= matrix.length;
        int m= matrix[0].length;
        int l= matrix[0][0]; int h= matrix[n-1][m-1];
        int ans=-1;

        while(l<=h){
            int gus=(l+h)/2;
            int a = fun(matrix,n,m,gus);
            if(a<k){
                l= gus+1;
            }
            else{
                ans= gus;
                h= gus-1;
            }
        }
        return ans;
    }

    public int fun(int[][] matrix, int n, int m, int gus){
        int r=n-1; int c=0; int count =0;
        while(r>=0 && c<m){
            if(matrix[r][c]<=gus){
                count=count+r+1;
                c++;
            }
            else{
                r--;
            }
        }
        return count;
    }

}