class Solution {
    public int minEatingSpeed(int[] piles, int h) {
        int max=0; int n= piles.length;
        for(int i=0;i<n;i++){
            max = Math.max(max, piles[i]);
        }
        int low=1; int high=max; int ans=-1;
        while(low<=high){
            int m= (low+high)/2;

            long t= time(piles , n , m);
            if(t>h){
                low=m+1;
            }
            else{
                ans=m;
                high = m-1;
            }
        }
        return ans;
    }

    public static long time(int[] piles, int n, int m){
        long t=0;
        for(int i=0; i<n;i++){
            t = t + piles[i]/m;

            if(piles[i]%m !=0){
                t++;
            }
        }
        return t;
    }
    
}