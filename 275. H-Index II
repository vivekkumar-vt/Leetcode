class Solution {
    public int hIndex(int[] citations) {
        int n= citations.length;
        int l=0; int h= n-1; 
        while(l<=h){
            int m= (l+h)/2;
            if(citations[m] == n-m){
                return n-m;
            }
            else if(citations[m] < n-m){
                l = m+1;
            }
            else {
                h=m-1;
            }
        }
        return n-l;
    }
}